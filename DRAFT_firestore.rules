rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Auth tokens don't have custom claims, so we check the users collection
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) && 
             data.keys().size() <= 7 &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['admin', 'employee'] &&
             (data.photoURL == null || data.photoURL is string) &&
             (data.onboarded == null || data.onboarded is bool);
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['userId', 'type', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.type in ['clock-in', 'clock-out'] &&
             data.timestamp == request.time &&
             (data.userName is string && data.userName.size() <= 100) &&
             (data.location == null || (
               data.location.latitude is number && 
               data.location.longitude is number
             ));
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'assignedTo', 'status']) &&
             data.title is string && data.title.size() <= 200 &&
             data.assignedTo is string &&
             data.status in ['todo', 'in-progress', 'done'] &&
             (data.progress == null || (data.progress is number && data.progress >= 0 && data.progress <= 100));
    }

    function isValidLeaveRequest(data) {
      return data.keys().hasAll(['userId', 'type', 'startDate', 'endDate', 'status']) &&
             data.userId == request.auth.uid &&
             data.type in ['sick', 'vacation', 'other'] &&
             data.status == 'pending' && // Initial status must be pending
             data.startDate is string &&
             data.endDate is string;
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == existing().role; // Cannot change own role
      allow delete: if false;
    }

    // Attendance
    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidAttendance(incoming());
      allow update, delete: if false; // Logs are immutable
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.assignedTo == request.auth.uid);
      allow create: if isAdmin() && isValidTask(incoming());
      allow update: if isSignedIn() && (
        // Admin can update everything
        (isAdmin() && isValidTask(incoming())) ||
        // Employee can only update progress and status
        (isOwner(resource.data.assignedTo) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['progress', 'status']) &&
         incoming().progress is number &&
         incoming().status in ['todo', 'in-progress', 'done'])
      );
      allow delete: if isAdmin();
    }

    // Leave Requests
    match /leave_requests/{requestId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidLeaveRequest(incoming());
      allow update: if isSignedIn() && (
        // Admin can update status
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        // User could potentially cancel (not implemented in UI but good for safety)
        (isOwner(resource.data.userId) && existing().status == 'pending' && incoming().status == 'cancelled')
      );
      allow delete: if isAdmin();
    }

    // Whitelist (Read only during registration)
    match /whitelist/{email} {
      allow get: if isSignedIn() && request.auth.token.email == email;
      allow list, write: if false; // Managed manually/server-side
    }
  }
}
